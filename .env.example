# Database
DATABASE_URL=postgresql+asyncpg://radar:radar_password@localhost:5432/social_radar
DATABASE_SYNC_URL=postgresql://radar:radar_password@localhost:5432/social_radar

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Object Storage (MinIO/S3)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=radar-content

# LLM Providers
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Embedding Provider (openai, local)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSION=1536

# LLM Provider (openai, anthropic, local)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4-turbo-preview
LLM_TEMPERATURE=0.7

# Local Model Settings (if using local provider)
LOCAL_MODEL_PATH=/path/to/models
VLLM_ENDPOINT=http://localhost:8000

# Security
SECRET_KEY=your-secret-key-change-this-in-production
ENCRYPTION_KEY=your-encryption-key-32-bytes-base64

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
CORS_ORIGINS=["http://localhost:3000"]

# MCP Server
MCP_HOST=0.0.0.0
MCP_PORT=8001

# Ingestion Settings
INGESTION_INTERVAL_MINUTES=15
MAX_ITEMS_PER_FETCH=100

# Content Settings
MAX_CONTENT_AGE_DAYS=30
CLUSTER_MIN_SIMILARITY=0.7
MAX_CLUSTERS_PER_DIGEST=20

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Feature Flags
ENABLE_VIDEO_TRANSCRIPTION=true
ENABLE_AUTO_CLUSTERING=true
ENABLE_PERSONALIZATION=true

